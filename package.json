{
  "name": "gait-quality-gate",
  "displayName": "gait — Guarded Agent Integration Tool",
  "description": "⚠️ Experimental — Quality gate and pilot for AI coding agents (personal project, not production-ready)",
  "version": "0.3.2",
  "publisher": "arodroz",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/arodroz/gait"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Testing",
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.gait/config.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gait.init",
        "title": "Gait: Initialize Project"
      },
      {
        "command": "gait.gate",
        "title": "Gait: Run Quality Gate"
      },
      {
        "command": "gait.runLint",
        "title": "Gait: Run Lint"
      },
      {
        "command": "gait.runTest",
        "title": "Gait: Run Tests"
      },
      {
        "command": "gait.runTypecheck",
        "title": "Gait: Run Typecheck"
      },
      {
        "command": "gait.runBuild",
        "title": "Gait: Run Build"
      },
      {
        "command": "gait.openDashboard",
        "title": "Gait: Open Dashboard"
      },
      {
        "command": "gait.release",
        "title": "Gait: Release"
      },
      {
        "command": "gait.installHook",
        "title": "Gait: Install Pre-Commit Hook"
      },
      {
        "command": "gait.runAgent",
        "title": "Gait: Run Agent"
      },
      {
        "command": "gait.rollback",
        "title": "Gait: Rollback Assistant"
      },
      {
        "command": "gait.recover",
        "title": "Gait: Recover (Cleanup)"
      },
      {
        "command": "gait.preflight",
        "title": "Gait: Environment Check"
      },
      {
        "command": "gait.generateAgentsMd",
        "title": "Gait: Generate AGENTS.md"
      },
      {
        "command": "gait.runScript",
        "title": "Gait: Run Script"
      },
      {
        "command": "gait.listScripts",
        "title": "Gait: List Scripts"
      },
      {
        "command": "gait.detectScripts",
        "title": "Gait: Detect Script Patterns"
      },
      { "command": "gait.snapshot", "title": "Gait: Take Snapshot" },
      { "command": "gait.restoreSnapshot", "title": "Gait: Restore Snapshot" },
      { "command": "gait.switchProfile", "title": "Gait: Switch Pipeline Profile" },
      { "command": "gait.createPR", "title": "Gait: Create Pull Request" },
      { "command": "gait.runWorkflow", "title": "Gait: Run Workflow" },
      { "command": "gait.costSummary", "title": "Gait: Cost Summary" },
      { "command": "gait.editMemory", "title": "Gait: Edit Agent Memory" },
      { "command": "gait.viewMemory", "title": "Gait: View Memory" },
      { "command": "gait.codeReview", "title": "Gait: AI Code Review" },
      { "command": "gait.generateTestsForFile", "title": "Gait: Generate Tests for File" },
      { "command": "gait.auditDeps", "title": "Gait: Audit Dependencies" },
      { "command": "gait.installAllHooks", "title": "Gait: Install All Hooks" },
      { "command": "gait.manageHooks", "title": "Gait: Manage Hooks" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gait",
          "title": "Gait",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "gait": [
        { "id": "gait.pipeline", "name": "Pipeline" },
        { "id": "gait.scripts", "name": "Scripts" },
        { "id": "gait.actions", "name": "Quick Actions" },
        { "id": "gait.info", "name": "Project" }
      ]
    },
    "keybindings": [
      {
        "command": "gait.gate",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "gait.openDashboard",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "gait.initialized"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/webview/main.ts --bundle --outfile=out/webview.js --format=iife --sourcemap",
    "watch": "npm run compile -- --watch",
    "lint": "tsc --noEmit && eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run compile -- --minify"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "smol-toml": "^1.3.0"
  }
}
