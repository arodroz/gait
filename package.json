{
  "name": "gait",
  "displayName": "gait — Guarded Agent Integration Tool",
  "description": "Quality gate and pilot for AI coding agents",
  "version": "0.1.0",
  "publisher": "tuni",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Testing",
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.gait/config.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gait.init",
        "title": "Gait: Initialize Project"
      },
      {
        "command": "gait.gate",
        "title": "Gait: Run Quality Gate"
      },
      {
        "command": "gait.runLint",
        "title": "Gait: Run Lint"
      },
      {
        "command": "gait.runTest",
        "title": "Gait: Run Tests"
      },
      {
        "command": "gait.runTypecheck",
        "title": "Gait: Run Typecheck"
      },
      {
        "command": "gait.runBuild",
        "title": "Gait: Run Build"
      },
      {
        "command": "gait.openDashboard",
        "title": "Gait: Open Dashboard"
      },
      {
        "command": "gait.release",
        "title": "Gait: Release"
      },
      {
        "command": "gait.installHook",
        "title": "Gait: Install Pre-Commit Hook"
      },
      {
        "command": "gait.runAgent",
        "title": "Gait: Run Agent"
      },
      {
        "command": "gait.rollback",
        "title": "Gait: Rollback Assistant"
      },
      {
        "command": "gait.recover",
        "title": "Gait: Recover (Cleanup)"
      },
      {
        "command": "gait.preflight",
        "title": "Gait: Environment Check"
      },
      {
        "command": "gait.generateAgentsMd",
        "title": "Gait: Generate AGENTS.md"
      },
      {
        "command": "gait.runScript",
        "title": "Gait: Run Script"
      },
      {
        "command": "gait.listScripts",
        "title": "Gait: List Scripts"
      },
      {
        "command": "gait.detectScripts",
        "title": "Gait: Detect Script Patterns"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gait",
          "title": "Gait",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "gait": [
        {
          "id": "gait.pipeline",
          "name": "Pipeline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gait.gate",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "gait.openDashboard",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "gait.initialized"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/webview/main.ts --bundle --outfile=out/webview.js --format=iife --sourcemap",
    "watch": "npm run compile -- --watch",
    "lint": "tsc --noEmit && eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run compile -- --minify"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "^0.24.0",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "smol-toml": "^1.3.0"
  }
}
