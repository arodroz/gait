{
  "name": "gait-quality-gate",
  "displayName": "HITL-Gate — Human-in-the-Loop for AI Agents",
  "description": "⚠️ Experimental — Intercept, evaluate, and decide on AI agent actions before they write code",
  "version": "0.4.2",
  "publisher": "arodroz",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/arodroz/gait"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Testing",
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.gait/config.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gait.init",
        "title": "HITL-Gate: Initialize Project"
      },
      {
        "command": "gait.openDashboard",
        "title": "HITL-Gate: Open Dashboard"
      },
      {
        "command": "gait.runAgent",
        "title": "HITL-Gate: Run Agent"
      },
      {
        "command": "gait.rollback",
        "title": "HITL-Gate: Rollback Assistant"
      },
      {
        "command": "gait.recover",
        "title": "HITL-Gate: Recover (Cleanup)"
      },
      {
        "command": "gait.preflight",
        "title": "HITL-Gate: Environment Check"
      },
      {
        "command": "gait.snapshot",
        "title": "HITL-Gate: Take Snapshot"
      },
      {
        "command": "gait.restoreSnapshot",
        "title": "HITL-Gate: Restore Snapshot"
      },
      {
        "command": "gait.runWorkflow",
        "title": "HITL-Gate: Run Workflow"
      },
      {
        "command": "gait.costSummary",
        "title": "HITL-Gate: Cost Summary"
      },
      {
        "command": "gait.editMemory",
        "title": "HITL-Gate: Edit Agent Memory"
      },
      {
        "command": "gait.viewMemory",
        "title": "HITL-Gate: View Memory"
      },
      {
        "command": "gait.codeReview",
        "title": "HITL-Gate: AI Code Review"
      },
      {
        "command": "gait.installClaudeHooks",
        "title": "HITL-Gate: Install Claude Code Hooks"
      },
      {
        "command": "gait.runCodex",
        "title": "HITL-Gate: Run Codex Task"
      },
      {
        "command": "gait.openJournal",
        "title": "HITL-Gate: Open Decisions Journal"
      },
      {
        "command": "gait.exportJournal",
        "title": "HITL-Gate: Export Journal as Markdown"
      },
      {
        "command": "gait.generateAgentsMd",
        "title": "HITL-Gate: Generate AGENTS.md"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gait",
          "title": "HITL-Gate",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "gait": [
        {
          "id": "gait.decisions",
          "name": "Decisions"
        },
        {
          "id": "gait.actions",
          "name": "Quick Actions"
        },
        {
          "id": "gait.info",
          "name": "Project"
        },
        {
          "id": "gait.agents",
          "name": "Agents"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gait.openDashboard",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "gait.initialized"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/webview/main.ts --bundle --outfile=out/webview.js --format=iife --sourcemap && esbuild src/bridge/hitlgate-bridge.ts --bundle --outfile=out/hitlgate-bridge.js --platform=node --format=cjs --sourcemap",
    "watch": "npm run compile -- --watch",
    "lint": "tsc --noEmit && eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run compile -- --minify"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "openai": "^6.33.0",
    "smol-toml": "^1.3.0"
  }
}
